    <Import Project="$(NuGetPackageRoot)microsoft.net.illink.tasks/10.0.1/build/Microsoft.NET.ILLink.Tasks.props" Condition="Exists('$(NuGetPackageRoot)microsoft.net.illink.tasks/10.0.1/build/Microsoft.NET.ILLink.Tasks.props')" />
  </ImportGroup>
  <PropertyGroup Condition=" '$(TargetFramework)' == 'net10.0-maccatalyst' AND '$(ExcludeRestorePackageImports)' != 'true' ">
    <PkgUno_WinUI Condition=" '$(PkgUno_WinUI)' == '' ">/Users/mingtsunlee/.nuget/packages/uno.winui/5.2.161</PkgUno_WinUI>
    <PkgUno_WinUI_DevServer Condition=" '$(PkgUno_WinUI_DevServer)' == '' ">/Users/mingtsunlee/.nuget/packages/uno.winui.devserver/5.2.161</PkgUno_WinUI_DevServer>
    <PkgMicrosoft_NET_ILLink_Tasks Condition=" '$(PkgMicrosoft_NET_ILLink_Tasks)' == '' ">/Users/mingtsunlee/.nuget/packages/microsoft.net.illink.tasks/10.0.1</PkgMicrosoft_NET_ILLink_Tasks>
