<Page x:Class="AvatarFormsApp.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:AvatarFormsApp"
      Background="White">

    <Grid Background="White" 
          VerticalAlignment="Stretch" 
          HorizontalAlignment="Stretch">
        
        <StackPanel x:Name="LandingPage" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center" 
                    Spacing="20"
                    Visibility="Visible">
            <TextBlock Text="Welcome to Avatar Forms App!" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="Black"
                       TextAlignment="Center"/>
            <Button Content="Start Local AI Chat" Width="200" Height="50" Tag="local" Click="OnChatAIClicked" Foreground="White" Background="Blue"/>
            <Button Content="Start Cloud AI Chat" Width="200" Height="50" Tag="cloud" Click="OnChatAIClicked" Foreground="White" Background="Blue"/>
        </StackPanel>

        <Grid x:Name="ChatInterface" 
              Visibility="Collapsed" 
              Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer x:Name="ChatScroll" Grid.Row="0" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="ChatDisplay" TextWrapping="Wrap" FontSize="16" Foreground="Black" />
            </ScrollViewer>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
                <TextBox x:Name="UserInput" 
                        Width="500" 
                        Height="40" 
                        VerticalContentAlignment="Center"
                        PlaceholderText="Type your answer here..." 
                        KeyDown="OnInputKeyDown" 
                        Foreground="Black" 
                        Background="White"/> 
                <Button Content="Send" Click="OnSendClicked" Foreground="White" Background="Green"/> 
            </StackPanel>
        </Grid>
    </Grid>
</Page>