<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AvatarFormsApp.Views.AvatarPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AvatarFormsApp.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" Padding="0" Margin="0">
        <Grid x:Name="ChatInterface" Visibility="Visible" Margin="0"> 
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> 
                <RowDefinition Height="1*"/>    
                <RowDefinition Height="Auto"/> 
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="10,10,10,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Click="OnBackClicked" Background="Transparent" BorderBrush="Transparent">
                    <StackPanel Orientation="Horizontal">
                        <FontIcon Glyph="&#xE72B;" FontSize="16" Foreground="Gray"/>
                        <TextBlock Text=" Leave" VerticalAlignment="Center" Foreground="Gray"/>
                    </StackPanel>
                </Button>
                <AppBarToggleButton x:Name="SettingsToggle"
                                    Grid.Column="2"
                                    Width="48"
                                    Height="48"
                                    Padding="0"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    ToolTipService.ToolTip="Settings"
                                    Checked="OnSettingsToggleChanged"
                                    Unchecked="OnSettingsToggleChanged">
                    <AppBarToggleButton.Icon>
                        <FontIcon Glyph="&#xE713;" FontSize="24" Foreground="#444"/>
                    </AppBarToggleButton.Icon>
                </AppBarToggleButton>
                <AppBarToggleButton x:Name="ConsoleToggle"
                                    Grid.Column="3"
                                    Width="48"
                                    Height="48"
                                    Padding="0"
                                    VerticalAlignment="Center"
                                    ToolTipService.ToolTip="Toggle console log"
                                    Checked="OnConsoleToggleChanged"
                                    Unchecked="OnConsoleToggleChanged">
                    <AppBarToggleButton.Icon>
                        <FontIcon Glyph="&#xE756;" FontSize="30" Foreground="#444"/>
                    </AppBarToggleButton.Icon>
                </AppBarToggleButton>
            </Grid>

            <Grid Grid.Row="1" Margin="10,0">
                <WebView2 x:Name="AvatarWebView" 
                          HorizontalAlignment="Stretch" 
                          VerticalAlignment="Stretch"
                          DefaultBackgroundColor="Transparent"/>

                <!-- Audio Connection Overlay -->
                <Border x:Name="AudioConnectionOverlay"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="#CC000000"
                        Visibility="Collapsed">
                    <Button x:Name="ConnectAudioButton"
                            Click="OnConnectAudioClicked"
                            Padding="12,8"
                            CornerRadius="6"
                            BorderThickness="1"
                            BorderBrush="#666666"
                            Background="#404040"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE767;" FontSize="16" Foreground="#CCCCCC"/>
                            <TextBlock Text="Click to connect audio" 
                                       FontSize="14" 
                                       FontWeight="Normal"
                                       Foreground="#CCCCCC"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Border>

                <!-- Settings Overlay -->
                <Border x:Name="SettingsOverlay"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="450"
                        MaxHeight="600"
                        Padding="0"
                        CornerRadius="8"
                        Background="#E61A1A1A"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        Visibility="Collapsed">
                    <Border.Shadow>
                        <ThemeShadow />
                    </Border.Shadow>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Header -->
                        <Border Grid.Row="0"
                                Background="#E61A1A1A"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="20,16">
                            <Grid>
                                <TextBlock Text="Settings"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Button Click="OnCloseSettingsClicked"
                                        HorizontalAlignment="Right"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        Width="32"
                                        Height="32"
                                        Padding="0">
                                    <FontIcon Glyph="&#xE711;" FontSize="12"/>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Settings Content -->
                        <ScrollViewer Grid.Row="1" 
                                      VerticalScrollBarVisibility="Auto"
                                      Padding="20,16">
                            <StackPanel Spacing="20">
                                
                                <!-- Voice Input Section -->
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Voice Input"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                    <Border Background="#E61A1A1A"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="16,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Spacing="4">
                                                <TextBlock Text="Auto-send message"
                                                           FontSize="14"
                                                           FontWeight="Medium"/>
                                                <TextBlock Text="Automatically send message after voice input completes"
                                                           FontSize="12"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <ToggleSwitch x:Name="AutoSendToggle"
                                                          Grid.Column="1"
                                                          VerticalAlignment="Center"
                                                          IsOn="True"
                                                          Toggled="OnAutoSendToggled"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Console Overlay -->
                <Border x:Name="ConsoleOverlay"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Stretch"
                        Width="360"
                        Margin="0,0,12,24"
                        Padding="0"
                        CornerRadius="8"
                        Background="#E61A1A1A"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        Visibility="Collapsed">
                    <Border.Shadow>
                        <ThemeShadow />
                    </Border.Shadow>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0"
                                Background="#E61A1A1A"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="20,16">
                            <TextBlock Text="Console Log"
                                       FontSize="14"
                                       FontWeight="Bold"/>
                        </Border>
                        <ScrollViewer x:Name="ChatScroll" Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16">
                            <RichTextBlock x:Name="ChatDisplay" TextWrapping="Wrap" FontSize="12" Foreground="{ThemeResource DefaultTextForegroundThemeBrush}"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="2" VerticalAlignment="Bottom" Margin="25,0,25,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="UserInput" 
                        Grid.Column="0"
                        Height="40"
                        AcceptsReturn="True"
                        TextWrapping="Wrap"
                        VerticalAlignment="Bottom"
                        VerticalContentAlignment="Center"
                        PlaceholderText="Type or click the mic to talk..." 
                        KeyDown="OnInputKeyDown" 
                        TextChanged="OnInputTextChanged"
                        Foreground="{ThemeResource DefaultTextForegroundThemeBrush}"
                        Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                        BorderBrush="LightGray"
                        BorderThickness="1"
                        CornerRadius="4"/> 

                <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="20,0,0,0" Spacing="8">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                        <Button x:Name="MicButton" 
                                Click="OnMicClicked"
                                Width="40" Height="40"
                                Padding="0"
                                CornerRadius="28"
                                HorizontalContentAlignment="Center" 
                                VerticalContentAlignment="Center"> 
                            <FontIcon x:Name="MicIcon" 
                                    Glyph="&#xE720;" 
                                    FontSize="20" 
                                    Foreground="White" 
                                    HorizontalAlignment="Center" 
                                    VerticalAlignment="Center"/> 
                        </Button>

                        <Button Content="Send" 
                                Click="OnSendClicked" 
                                Width="70" Height="40"
                                FontSize="14"
                                FontWeight="Bold"
                                CornerRadius="8"
                                BorderThickness="0"/> 
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid> 
    </Grid>
</Page>
