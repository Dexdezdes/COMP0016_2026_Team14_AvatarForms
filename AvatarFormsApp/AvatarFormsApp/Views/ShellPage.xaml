<Page
x:Class="AvatarFormsApp.Views.ShellPage"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:helpers="using:AvatarFormsApp.Helpers"
xmlns:behaviors="using:AvatarFormsApp.Behaviors"
xmlns:interactivity="using:Microsoft.Xaml.Interactivity"
xmlns:interactions="using:Microsoft.Xaml.Interactions.Core"
xmlns:models="using:AvatarFormsApp.Models"
Loaded="OnLoaded">
    <Page.Resources>
        <Thickness x:Key="NavigationViewContentMargin">0</Thickness>
        <Thickness x:Key="NavigationViewMinimalContentMargin">0</Thickness>
    </Page.Resources>

    <Grid>
        <NavigationView
            x:Name="NavigationViewControl"
            Margin="0"
            Padding="0"
            Canvas.ZIndex="0"
            IsBackButtonVisible="Visible"
            IsBackEnabled="{x:Bind ViewModel.IsBackEnabled, Mode=OneWay}"
            SelectedItem="{x:Bind ViewModel.Selected, Mode=OneWay}"
            IsSettingsVisible="False"
            VerticalAlignment="Stretch" 
            HorizontalAlignment="Stretch"
            AlwaysShowHeader="False"
            IsTitleBarAutoPaddingEnabled="False"
            ItemInvoked="OnItemInvoked"
            Header="{x:Null}"
            PaneDisplayMode="Left">

            <!-- Pane header (logo + app name) -->
            <NavigationView.PaneHeader>
                <StackPanel Orientation="Horizontal" Margin="8,8">
                    <TextBlock Text=" AvatarForms" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#FFFFFFFF" />
                </StackPanel>
            </NavigationView.PaneHeader>

            <NavigationView.MenuItems>
                <!-- Overview section -->
                <NavigationViewItemHeader Content="Overview" />
                <NavigationViewItem Content="Dashboard" x:Name="Nav_Dashboard" IsSelected="True" Tag="DashboardPageViewModel">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xe80f;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <!-- Questionnaires section with dropdown -->
                <NavigationViewItem x:Name="Nav_Questionnaires" Content="Questionnaires">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xe8a5;" />
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.MenuItems>
                        <!-- Dynamically bind questionnaires from database -->
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.AvailableQuestionnaires, Mode=OneWay}">
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="models:Questionnaire">
                                    <NavigationViewItem Content="{x:Bind Name}" Tag="{x:Bind Id}">
                                        <NavigationViewItem.Icon>
                                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xe8a5;" FontSize="12" />
                                        </NavigationViewItem.Icon>
                                    </NavigationViewItem>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </NavigationViewItem.MenuItems>
                </NavigationViewItem>

                <!-- Responses section -->
                <NavigationViewItem x:Name="Nav_Responses" Content="Responses">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xe8d7;" />
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.MenuItems>
                        <!-- Dynamically bind questionnaires from database -->
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.AvailableQuestionnaires, Mode=OneWay}">
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="models:Questionnaire">
                                    <NavigationViewItem Content="{x:Bind Name}" Tag="{x:Bind Id}">
                                        <NavigationViewItem.Icon>
                                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xe8a5;" FontSize="12" />
                                        </NavigationViewItem.Icon>
                                    </NavigationViewItem>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </NavigationViewItem.MenuItems>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <!-- Pane footer for profile -->
            <NavigationView.PaneFooter>
                <StackPanel Orientation="Horizontal" Margin="12" VerticalAlignment="Bottom">
                    <Ellipse Width="36" Height="36" Fill="#DDDDDD" />
                    <StackPanel Margin="8,0">
                        <TextBlock Text="John Smith" FontWeight="SemiBold" />
                        <TextBlock Text="Admin" FontSize="12" Foreground="#888888" />
                    </StackPanel>
                </StackPanel>
            </NavigationView.PaneFooter>

            <Grid Margin="0">
                <Frame x:Name="NavigationFrame"
                    HorizontalContentAlignment="Stretch" 
                    VerticalContentAlignment="Stretch" />
            </Grid>
        </NavigationView>
    </Grid>
</Page>
