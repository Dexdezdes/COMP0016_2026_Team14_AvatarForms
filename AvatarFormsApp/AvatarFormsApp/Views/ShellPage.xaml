<Page
    x:Class="AvatarFormsApp.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:AvatarFormsApp.Helpers"
    xmlns:behaviors="using:AvatarFormsApp.Behaviors"
    xmlns:i="using:Microsoft.Xaml.Interactivity"
    Loaded="OnLoaded">

    <Grid>
        <Grid x:Name="AppTitleBar"
              Canvas.ZIndex="1"
              Height="{Binding ElementName=NavigationViewControl, Path=CompactPaneLength}"
              IsHitTestVisible="True"
              VerticalAlignment="Top">
            <Image Source="/Assets/WindowIcon.ico"
                   HorizontalAlignment="Left"
                   Width="16"
                   Height="16" />
            <TextBlock x:Name="AppTitleBarText"
                       VerticalAlignment="Center"
                       TextWrapping="NoWrap"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Margin="28,0,0,0"/>
        </Grid>
        <NavigationView
            x:Name="NavigationViewControl"
            Canvas.ZIndex="0"
            IsBackButtonVisible="Visible"
            IsBackEnabled="{x:Bind ViewModel.IsBackEnabled, Mode=OneWay}"
            SelectedItem="{x:Bind ViewModel.Selected, Mode=OneWay}"
            IsSettingsVisible="False"
            ExpandedModeThresholdWidth="1280"
            ItemInvoked="OnItemInvoked"
            DisplayModeChanged="NavigationViewControl_DisplayModeChanged"
            Header="{x:Bind ((ContentControl)ViewModel.Selected).Content, Mode=OneWay}">

            <!-- Pane header (logo + app name) -->
            <NavigationView.PaneHeader>
                <StackPanel Orientation="Horizontal" Margin="8,8">
                    <TextBlock Text=" AvatarForms" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#FFFFFFFF" />
                </StackPanel>
            </NavigationView.PaneHeader>

            <NavigationView.MenuItems>
                <!-- Overview section -->
                <NavigationViewItemHeader Content="Overview" />
                <NavigationViewItem Content="Dashboard" x:Name="Nav_Dashboard" IsSelected="True">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xe80f;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <!-- Avatars section with subitems -->
                <NavigationViewItem x:Name="Nav_Avatars" Content="Avatars">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xe77b;" />
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.MenuItems>
                        <NavigationViewItem Content="DASS Questionnaire" />
                        <NavigationViewItem Content="Learning Experience Survey" />
                        <NavigationViewItem Content="Examination Feedback Survey" />
                        <NavigationViewItem Content="Student Health Questionnaire" />
                        <NavigationViewItem Content="Year End Review" />
                    </NavigationViewItem.MenuItems>
                </NavigationViewItem>

                <!-- Responses section -->
                <NavigationViewItem x:Name="Nav_Responses" Content="Responses">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xe8d7;" />
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.MenuItems>
                        <NavigationViewItem Content="DASS Questionnaire" />
                        <NavigationViewItem Content="Learning Experience Survey" />
                        <NavigationViewItem Content="Examination Feedback Survey" />
                        <NavigationViewItem Content="Student Health Questionnaire" />
                        <NavigationViewItem Content="Year End Review" />
                    </NavigationViewItem.MenuItems>
                </NavigationViewItem>

                <NavigationViewItem x:Name="Nav_Conversation" 
                            Content="AI Chat"
                            Tag="ConversationPageViewModel">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8BD;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <!-- Pane footer for profile -->
            <NavigationView.PaneFooter>
                <StackPanel Orientation="Horizontal" Margin="12" VerticalAlignment="Bottom">
                    <Ellipse Width="36" Height="36" Fill="#DDDDDD" />
                    <StackPanel Margin="8,0">
                        <TextBlock Text="John Smith" FontWeight="SemiBold" />
                        <TextBlock Text="Admin" FontSize="12" Foreground="#888888" />
                    </StackPanel>
                </StackPanel>
            </NavigationView.PaneFooter>

            <NavigationView.HeaderTemplate>
                <DataTemplate>
                    <Grid>
                        <TextBlock Text="{Binding}" Style="{ThemeResource TitleTextBlockStyle}" />
                    </Grid>
                </DataTemplate>
            </NavigationView.HeaderTemplate>

            <i:Interaction.Behaviors>
                <behaviors:NavigationViewHeaderBehavior
                    DefaultHeader="{x:Bind ((ContentControl)ViewModel.Selected).Content, Mode=OneWay}">
                    <behaviors:NavigationViewHeaderBehavior.DefaultHeaderTemplate>
                        <DataTemplate>
                            <Grid>
                                <TextBlock Text="Dashboard" FontSize="18" FontWeight="SemiBold" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,12,0">
                                    <TextBlock Text="About" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center" />
                                    <TextBlock Text="Help" FontSize="18" VerticalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </behaviors:NavigationViewHeaderBehavior.DefaultHeaderTemplate>
                </behaviors:NavigationViewHeaderBehavior>
            </i:Interaction.Behaviors>

            <Grid Margin="{StaticResource NavigationViewPageContentMargin}">
                <Frame x:Name="NavigationFrame" />
            </Grid>
        </NavigationView>
    </Grid>
</Page>