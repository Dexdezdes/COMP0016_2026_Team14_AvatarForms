<Page x:Class="AvatarFormsApp.Views.ConversationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:AvatarFormsApp"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" Padding="0" Margin="0">
        <StackPanel x:Name="LandingPage" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center" 
                    Spacing="20"
                    Canvas.ZIndex="2">
            <TextBlock Text="Welcome to Avatar Forms App!" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="{ThemeResource DefaultTextForegroundThemeBrush}"
                       TextAlignment="Center"/>
            <Button Content="Start Local AI Chat" Width="200" Height="50" Tag="local" Click="OnChatAIClicked" Foreground="White" Background="Blue"/>
            <Button Content="Start Cloud AI Chat" Width="200" Height="50" Tag="cloud" Click="OnChatAIClicked" Foreground="White" Background="Blue"/>
        </StackPanel>

        <Grid x:Name="ChatInterface" Opacity="0" IsHitTestVisible="False" Canvas.ZIndex="1" Margin="0"> 
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> 
                <RowDefinition Height="450"/>    
                <RowDefinition Height="*"/>  
                <RowDefinition Height="Auto"/> 
            </Grid.RowDefinitions>

            <Button Grid.Row="0" Click="OnBackClicked" Background="Transparent" BorderBrush="Transparent" Margin="0,10,0,10">
                <StackPanel Orientation="Horizontal">
                    <FontIcon Glyph="&#xE72B;" FontSize="16" Foreground="Gray"/>
                    <TextBlock Text=" Back" VerticalAlignment="Center" Foreground="Gray"/>
                </StackPanel>
            </Button>

            <WebView2 x:Name="AvatarWebView" 
              Grid.Row="1" 
              Margin="10"
              HorizontalAlignment="Stretch" 
              VerticalAlignment="Stretch"
              DefaultBackgroundColor="Transparent"/>

            <ScrollViewer x:Name="ChatScroll" Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,10" HorizontalAlignment="Stretch">
                <TextBlock x:Name="ChatDisplay" TextWrapping="Wrap" FontSize="16" Foreground="{ThemeResource DefaultTextForegroundThemeBrush}" HorizontalAlignment="Stretch"/>
            </ScrollViewer>

            <Grid Grid.Row="3" VerticalAlignment="Bottom" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="UserInput" 
                        Grid.Column="0"
                        MinHeight="50" 
                        MaxHeight="150"
                        AcceptsReturn="True"
                        TextWrapping="Wrap"
                        VerticalAlignment="Bottom"
                        VerticalContentAlignment="Center"
                        PlaceholderText="Type or click the mic to talk..." 
                        KeyDown="OnInputKeyDown" 
                        TextChanged="OnInputTextChanged"
                        Foreground="{ThemeResource DefaultTextForegroundThemeBrush}"
                        Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                        BorderBrush="LightGray"
                        BorderThickness="1"
                        CornerRadius="4"/> 

                <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="15,0,0,0" Spacing="8">
                    
                    <Border Background="#F9F9F9" CornerRadius="8" Padding="12,0" BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Auto-send" VerticalAlignment="Center" Foreground="#666666" FontSize="14"/>
                            <ToggleSwitch x:Name="AutoSendToggle" 
                                        IsOn="True" 
                                        Toggled="OnAutoSendToggled"
                                        MinWidth="0"/> 
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                        <Button x:Name="MicButton" 
                                Click="OnMicClicked"
                                Width="55" Height="55"
                                Padding="0"
                                CornerRadius="28"
                                HorizontalContentAlignment="Center" 
                                VerticalContentAlignment="Center"> 
                            <FontIcon x:Name="MicIcon" 
                                    Glyph="&#xE720;" 
                                    FontSize="24" 
                                    Foreground="White" 
                                    HorizontalAlignment="Center" 
                                    VerticalAlignment="Center"/> 
                        </Button>

                        <Button Content="Send" 
                                Click="OnSendClicked" 
                                Width="105" Height="55"
                                FontSize="18"
                                FontWeight="Bold"
                                Foreground="White" 
                                Background="#2E7D32" 
                                CornerRadius="8"
                                BorderThickness="0"/> 
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid> 
    </Grid>
</Page>