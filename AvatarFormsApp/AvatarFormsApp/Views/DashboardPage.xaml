<Page
    x:Class="AvatarFormsApp.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:AvatarFormsApp.Models"
    mc:Ignorable="d">

    <Grid x:Name="ContentArea" Padding="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="1" Margin="0,27,0,0">
            <TextBlock Text="Welcome to AvatarForms" FontSize="30" FontWeight="SemiBold" Margin="24,0,0,0"/>
            <TextBlock Text="Check out latest responses" Foreground="Gray" FontSize="16"  Margin="24,6,0,6" />

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="24,12,0,12">
                <!-- Filter ComboBox with Binding -->
                <ComboBox x:Name="FilterComboBox"
                          Width="300" 
                          Margin="0,0,12,0" 
                          FontSize="16"
                          SelectedIndex="0"
                          SelectedItem="{x:Bind ViewModel.SelectedFilter, Mode=TwoWay}">
                    <x:String>All Questionnaires</x:String>
                </ComboBox>

                <!-- Sort ComboBox with Binding -->
                <ComboBox x:Name="SortComboBox"
                          Width="270" 
                          Margin="18,0" 
                          FontSize="16"
                          HorizontalAlignment="Right"
                          SelectedIndex="0"
                          SelectedItem="{x:Bind ViewModel.SelectedSort, Mode=TwoWay}">
                    <x:String>Sort by name (A-Z)</x:String>
                    <x:String>Sort by name (Z-A)</x:String>
                    <x:String>Sort by responses</x:String>
                </ComboBox>

                <!-- Search TextBox with Binding -->
                <TextBox x:Name="SearchBox"
                         Width="330" 
                         FontSize="16"
                         PlaceholderText="Search for questionnaires..." 
                         HorizontalAlignment="Right" 
                         Margin="18,0"
                         Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <!-- Empty State -->
            <StackPanel x:Name="EmptyState"
                        Visibility="{x:Bind ViewModel.HasQuestionnaires, Mode=OneWay, Converter={StaticResource BoolToVisibilityInverseConverter}}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="0,90,0,0">
                <FontIcon Glyph="&#xE8F1;" FontSize="96" Foreground="Gray" HorizontalAlignment="Center" />
                <TextBlock Text="No questionnaires available" 
                           FontSize="27" 
                           Foreground="Gray" 
                           Margin="0,24,0,12"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Upload a questionnaire to get started" 
                           FontSize="21" 
                           Foreground="Gray" 
                           HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Questionnaire List -->
            <ListView x:Name="QuestionnaireList" 
                      Margin="0" 
                      SelectionMode="Single"
                      ItemsSource="{x:Bind ViewModel.FilteredQuestionnaires, Mode=OneWay}"
                      Visibility="{x:Bind ViewModel.HasQuestionnaires, Mode=OneWay}"
                      ItemClick="OnQuestionnaireClick"
                      IsItemClickEnabled="True">
                <ListView.Header>
                    <Grid Padding="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="210" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Questionnaire" FontWeight="Bold" Margin="24,0,0,0" FontSize="18" />
                        <TextBlock Grid.Column="1" Text="Responses" FontWeight="Bold" HorizontalAlignment="Center" FontSize="18" />
                        <TextBlock Grid.Column="2" Text="Actions" FontWeight="Bold" HorizontalAlignment="Center" FontSize="18" />
                    </Grid>
                </ListView.Header>

                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:Questionnaire">
                        <Grid Padding="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="210" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Rectangle Width="6" Fill="{x:Bind Color}" Margin="0,0,18,0" RadiusX="3" RadiusY="3" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" FontSize="21" />
                                    <ProgressBar Value="100" Minimum="0" Maximum="100" Height="3" Foreground="{x:Bind Color}" Margin="0,12,18,0" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Grid.Column="1" 
                                       Text="{x:Bind ResponseSessions.Count}"
                                       FontSize="21"
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center" />

                            <Button Grid.Column="2"
                                    Content="&#xE74D;"
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="24"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Padding="12"
                                    ToolTipService.ToolTip="Delete questionnaire"
                                    Click="OnDeleteClick"
                                    Tag="{x:Bind Id}">
                                <Button.Resources>
                                    <ResourceDictionary>
                                        <SolidColorBrush x:Key="ButtonForeground"             Color="Red" />
                                        <SolidColorBrush x:Key="ButtonForegroundPointerOver"  Color="Red" />
                                        <SolidColorBrush x:Key="ButtonForegroundPressed"      Color="Red" />
                                        <SolidColorBrush x:Key="ButtonBackground"             Color="Transparent" />
                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver"  Color="#15C42B1C" />
                                        <SolidColorBrush x:Key="ButtonBackgroundPressed"      Color="#25C42B1C" />
                                    </ResourceDictionary>
                                </Button.Resources>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Button Content="Upload Questionnaire"
                    x:Name="UploadButton"
                    Click="OnUploadClick"
                    HorizontalAlignment="Right"
                    Style="{StaticResource AccentButtonStyle}"
                    Margin="0,30,36,30"
                    FontSize="18"
                    Padding="18,8" />
        </StackPanel>
    </Grid>
</Page>
