<Page
    x:Class="AvatarFormsApp.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:AvatarFormsApp.Models"
    mc:Ignorable="d">

    <Grid x:Name="ContentArea" Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="1" Margin="0,18,0,0">
            <TextBlock Text="Welcome to AvatarForms" FontSize="20" FontWeight="SemiBold" />
            <TextBlock Text="Check out latest responses" Foreground="Gray" Margin="0,4,0,12" />

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,6,0,12">
                <!-- Filter ComboBox with Binding -->
                <ComboBox x:Name="FilterComboBox"
                          Width="200" 
                          Margin="0,0,8,0" 
                          SelectedIndex="0"
                          SelectedItem="{x:Bind ViewModel.SelectedFilter, Mode=TwoWay}">
                    <x:String>All Questionnaires</x:String>
                </ComboBox>

                <!-- Sort ComboBox with Binding -->
                <ComboBox x:Name="SortComboBox"
                          Width="180" 
                          Margin="12,0" 
                          HorizontalAlignment="Right"
                          SelectedIndex="0"
                          SelectedItem="{x:Bind ViewModel.SelectedSort, Mode=TwoWay}">
                    <x:String>Sort by name (A-Z)</x:String>
                    <x:String>Sort by name (Z-A)</x:String>
                    <x:String>Sort by responses</x:String>
                </ComboBox>

                <!-- Search TextBox with Binding -->
                <TextBox x:Name="SearchBox"
                         Width="220" 
                         PlaceholderText="Search for questionnaires..." 
                         HorizontalAlignment="Right" 
                         Margin="12,0"
                         Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <!-- Empty State -->
            <StackPanel x:Name="EmptyState"
                        Visibility="{x:Bind ViewModel.HasQuestionnaires, Mode=OneWay, Converter={StaticResource BoolToVisibilityInverseConverter}}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="0,60,0,0">
                <FontIcon Glyph="&#xE8F1;" FontSize="64" Foreground="Gray" HorizontalAlignment="Center" />
                <TextBlock Text="No questionnaires available" 
                           FontSize="18" 
                           Foreground="Gray" 
                           Margin="0,16,0,8"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Upload a questionnaire to get started" 
                           FontSize="14" 
                           Foreground="Gray" 
                           HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Questionnaire List -->
            <ListView x:Name="QuestionnaireList" 
                      Margin="0" 
                      SelectionMode="Single"
                      ItemsSource="{x:Bind ViewModel.FilteredQuestionnaires, Mode=OneWay}"
                      Visibility="{x:Bind ViewModel.HasQuestionnaires, Mode=OneWay}"
                      ItemClick="OnQuestionnaireClick"
                      IsItemClickEnabled="True">
                <ListView.Header>
                    <Grid Padding="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Questionnaire" FontWeight="Bold" Margin="16,0,0,0" />
                        <TextBlock Grid.Column="1" Text="Responses" FontWeight="Bold" HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="Actions" FontWeight="Bold" HorizontalAlignment="Center" />
                    </Grid>
                </ListView.Header>

                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:Questionnaire">
                        <Grid Padding="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="80" />
                            </Grid.ColumnDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Rectangle Width="4" Fill="{x:Bind Color}" Margin="0,0,12,0" RadiusX="2" RadiusY="2" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" />
                                    <ProgressBar Value="100" Minimum="0" Maximum="100" Height="2" Foreground="{x:Bind Color}" Margin="0,8,12,0" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Grid.Column="1" 
                                       Text="{x:Bind ResponseSessions.Count}"
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center" />

                            <Button Grid.Column="2"
                                    Content="&#xE74D;"
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="16"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Background="Transparent"
                                    Foreground="#C42B1C"
                                    BorderThickness="0"
                                    Padding="8"
                                    ToolTipService.ToolTip="Delete questionnaire"
                                    Click="OnDeleteClick"
                                    Tag="{x:Bind Id}">
                                <Button.Resources>
                                    <ResourceDictionary>
                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#10C42B1C" />
                                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#20C42B1C" />
                                    </ResourceDictionary>
                                </Button.Resources>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Button Content="Upload Questionnaire"
                    x:Name="UploadButton"
                    Click="OnUploadClick"
                    HorizontalAlignment="Right"
                    Style="{StaticResource AccentButtonStyle}"
                    Margin="0,20,45,0" />
        </StackPanel>
    </Grid>
</Page>
