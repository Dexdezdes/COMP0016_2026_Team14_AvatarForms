<Page
    x:Class="AvatarFormsApp.Views.ResponsesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:AvatarFormsApp.Models"
    mc:Ignorable="d">

    <Grid x:Name="ContentArea" Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="1" Margin="0,18,0,0">
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="14,0,0,4">
                        <TextBlock Text="{x:Bind ViewModel.QuestionnaireName, Mode=OneWay}"
                           FontSize="20" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="Responses for this questionnaire"
                       Foreground="Gray" Margin="14,0,0,0" />
                </StackPanel>
            </Grid>

            <!-- Empty State -->
            <StackPanel x:Name="EmptyState"
                        Visibility="{x:Bind ViewModel.HasResponseSessions, Mode=OneWay, Converter={StaticResource BoolToVisibilityInverseConverter}}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="0,60,0,0">
                <FontIcon Glyph="&#xE8D7;" FontSize="64" Foreground="Gray" HorizontalAlignment="Center" />
                <TextBlock Text="No responses yet"
                           FontSize="18"
                           Foreground="Gray"
                           Margin="0,16,0,8"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Response sessions will appear here once interviews are completed"
                           FontSize="14"
                           Foreground="Gray"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Response Sessions List -->
            <ListView x:Name="ResponseSessionList"
                      Margin="0"
                      SelectionMode="Single"
                      ItemsSource="{x:Bind ViewModel.ResponseSessions, Mode=OneWay}"
                      Visibility="{x:Bind ViewModel.HasResponseSessions, Mode=OneWay}"
                      ItemClick="OnSessionClick"
                      IsItemClickEnabled="True">
                <ListView.Header>
                    <Grid Padding="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="100" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Session ID" FontWeight="Bold" Margin="16,0,0,0" />
                        <TextBlock Grid.Column="1" Text="Submitted" FontWeight="Bold" HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="Status" FontWeight="Bold" HorizontalAlignment="Center" />
                    </Grid>
                </ListView.Header>

                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:ResponseSession">
                        <Grid Padding="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="100" />
                            </Grid.ColumnDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Rectangle Width="4"
                                           Fill="{x:Bind Questionnaire.Color}"
                                           Margin="0,0,12,0" RadiusX="2" RadiusY="2" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{x:Bind Id}" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Foreground="Gray" FontSize="12" Margin="0,2,0,0">
                                        <Run Text="{x:Bind Responses.Count}" />
                                        <Run Text="answers" />
                                    </TextBlock>
                                </StackPanel>
                            </Grid>

                            <TextBlock Grid.Column="1"
                                       Text="{x:Bind SubmittedDate}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="13" />

                            <StackPanel Grid.Column="2"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <!-- Complete badge -->
                                <Border CornerRadius="4" Padding="8,3" Background="#1A22C55E"
                                        Visibility="{x:Bind IsComplete, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="Complete" FontSize="12" FontWeight="SemiBold" Foreground="#22C55E" />
                                </Border>
                                <!-- Incomplete badge -->
                                <Border CornerRadius="4" Padding="8,3" Background="#1AFFA500"
                                        Visibility="{x:Bind IsComplete, Converter={StaticResource BoolToVisibilityInverseConverter}}">
                                    <TextBlock Text="Incomplete" FontSize="12" FontWeight="SemiBold" Foreground="#FFA500" />
                                </Border>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Button Command="{x:Bind ViewModel.ExportAllTocsvCommand}"
                    Visibility="{x:Bind ViewModel.HasResponseSessions, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                    HorizontalAlignment="Right"
                    Margin="0,20,45,0"
                    Style="{StaticResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE896;" FontSize="14" />
                    <TextBlock Text="Download Responses" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Page>
