<Page
    x:Class="AvatarFormsApp.Views.CreateQuestionnairePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:AvatarFormsApp.Services"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <!-- Hidden WebView2 used purely for network interception -->
        <WebView2 x:Name="HiddenWebView"
                  Width="1" Height="1"
                  Opacity="0"
                  IsHitTestVisible="False"
                  VerticalAlignment="Top"
                  HorizontalAlignment="Left" />

        <ScrollViewer Padding="32">
            <StackPanel Spacing="20" MaxWidth="760">

                <!-- Title -->
                <TextBlock Text="Create Questionnaire"
                           Style="{StaticResource TitleTextBlockStyle}" />

                <!-- Questionnaire Name -->
                <StackPanel Spacing="6">
                    <TextBlock Text="Questionnaire Name" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBox PlaceholderText="Enter a name…"
                             Text="{x:Bind ViewModel.QuestionnaireName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <!-- Form Link — auto-parses on paste -->
                <StackPanel Spacing="6">
                    <TextBlock Text="Microsoft Forms Link" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBox x:Name="LinkTextBox"
                             PlaceholderText="Paste your forms.cloud.microsoft link here…"
                             Text="{x:Bind ViewModel.FormLink, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             TextChanged="LinkTextBox_TextChanged" />
                </StackPanel>

                <!-- File picker (optional) -->
                <StackPanel Spacing="6">
                    <TextBlock Text="Or upload a file (.csv / .xlsx)" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Browse…" Click="BrowseButton_Click" />
                        <TextBlock x:Name="PickedFileText"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>

                <!-- Progress -->
                <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                              Width="28" Height="28"
                              Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay,
                                           Converter={StaticResource BoolToVisibilityConverter}}" />

                <!-- Status message -->
                <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                           TextWrapping="Wrap"
                           Visibility="{x:Bind ViewModel.StatusMessage, Mode=OneWay,
                                        Converter={StaticResource StringToVisibilityConverter}}" />

                <!-- Parsed Questions Preview -->
                <StackPanel Spacing="8"
                            Visibility="{x:Bind ViewModel.HasParsedQuestions, Mode=OneWay,
                                         Converter={StaticResource BoolToVisibilityConverter}}">

                    <TextBlock Text="Parsed Questions Preview"
                               Style="{StaticResource SubtitleTextBlockStyle}" />

                    <ListView ItemsSource="{x:Bind ViewModel.ParsedQuestions, Mode=OneWay}"
                              SelectionMode="None"
                              MaxHeight="360">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:ParsedQuestion">
                                <Grid Padding="0,6" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Background="{ThemeResource AccentFillColorDefaultBrush}"
                                            CornerRadius="4" Padding="4,2"
                                            HorizontalAlignment="Center" VerticalAlignment="Top">
                                        <TextBlock Text="{x:Bind Index}"
                                                   Foreground="White" FontSize="12"
                                                   HorizontalAlignment="Center" />
                                    </Border>

                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="{x:Bind FullTitle}"
                                                   FontWeight="SemiBold" TextWrapping="Wrap"
                                                   Visibility="{x:Bind IsMatrix,
                                                                Converter={StaticResource BoolToVisibilityConverter}}" />
                                        <TextBlock Text="{x:Bind Title}"
                                                   TextWrapping="Wrap"
                                                   Visibility="{x:Bind IsMatrix,
                                                                Converter={StaticResource BoolToVisibilityInverseConverter}}" />
                                        <TextBlock Text="{x:Bind Type}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   FontSize="11" />
                                        <TextBlock Text="{x:Bind Subtitle}"
                                                   TextWrapping="Wrap" FontSize="12"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                   Visibility="{x:Bind Subtitle, Mode=OneWay,
                                                                Converter={StaticResource StringToVisibilityConverter}}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <!-- Action Buttons -->
                <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                    <Button Content="Clear" Click="ClearButton_Click" />
                    <Button Content="Cancel" Click="Cancel_Click" />
                    <Button Content="Create Questionnaire"
                            Style="{StaticResource AccentButtonStyle}"
                            Click="Create_Click"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay,
                                        Converter={StaticResource BoolNegationConverter}}" />
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
