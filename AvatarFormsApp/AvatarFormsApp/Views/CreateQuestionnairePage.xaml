<Page
    x:Class="AvatarFormsApp.Views.CreateQuestionnairePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:AvatarFormsApp.Services"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="32">
        <StackPanel Spacing="20" MaxWidth="760">

            <!-- Title -->
            <TextBlock Text="Create Questionnaire"
                       Style="{StaticResource TitleTextBlockStyle}" />

            <!-- Questionnaire Name -->
            <StackPanel Spacing="6">
                <TextBlock Text="Questionnaire Name" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <TextBox PlaceholderText="Enter a name…"
                         Text="{x:Bind ViewModel.QuestionnaireName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <!-- Form Link -->
            <StackPanel Spacing="6">
                <TextBlock Text="Microsoft Forms Link" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             PlaceholderText="https://forms.cloud.microsoft/…"
                             Text="{x:Bind ViewModel.FormLink, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <!-- "Upload Questionnaire" = parse link -->
                    <Button Grid.Column="1"
                            Content="Upload Questionnaire"
                            Command="{x:Bind ViewModel.ParseLinkCommand}"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}" />
                </Grid>
            </StackPanel>

            <!-- File picker (optional) -->
            <StackPanel Spacing="6">
                <TextBlock Text="Or upload a file (.csv / .xlsx)" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Browse…" Click="BrowseButton_Click" />
                    <TextBlock x:Name="PickedFileText"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </StackPanel>

            <!-- Status / progress -->
            <StackPanel Spacing="8" Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay}">
                <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" Width="28" Height="28" />
            </StackPanel>

            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                       Foreground="{ThemeResource SystemFillColorCautionBrush}"
                       TextWrapping="Wrap"
                       Visibility="{x:Bind ViewModel.StatusMessage, Mode=OneWay,
                                    Converter={StaticResource StringToVisibilityConverter}}" />

            <!-- Parsed Questions Preview -->
            <StackPanel Spacing="8"
                        Visibility="{x:Bind ViewModel.HasParsedQuestions, Mode=OneWay}">

                <TextBlock Text="Parsed Questions Preview"
                           Style="{StaticResource SubtitleTextBlockStyle}" />

                <ListView ItemsSource="{x:Bind ViewModel.ParsedQuestions, Mode=OneWay}"
                          SelectionMode="None"
                          MaxHeight="360">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:ParsedQuestion">
                            <Grid Padding="0,6" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Index badge -->
                                <Border Grid.Column="0"
                                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                                        CornerRadius="4"
                                        Padding="4,2"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Top">
                                    <TextBlock Text="{x:Bind Index}"
                                               Foreground="White"
                                               FontSize="12"
                                               HorizontalAlignment="Center" />
                                </Border>

                                <!-- Question details -->
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="{x:Bind FullTitle}" FontWeight="SemiBold"
                                               Visibility="{x:Bind IsMatrix, Converter={StaticResource BoolToVisibilityConverter}}" TextWrapping="Wrap" />
                                    <TextBlock Text="{x:Bind Title}" TextWrapping="Wrap"
                                               Visibility="{x:Bind IsMatrix, Converter={StaticResource BoolToVisibilityInverseConverter}}" />
                                    <TextBlock Text="{x:Bind Type}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               FontSize="11" />
                                    <TextBlock Text="{x:Bind Subtitle}" TextWrapping="Wrap"
                                               FontSize="12"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                               Visibility="{x:Bind Subtitle,
                                                            Converter={StaticResource StringToVisibilityConverter}}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

            <!-- Action Buttons -->
            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                <Button Content="Clear" Click="ClearButton_Click" />
                <Button Content="Cancel" Click="Cancel_Click" />
                <Button Content="Create Questionnaire"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="Create_Click"
                        IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay,
                                    Converter={StaticResource BoolNegationConverter}}" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
