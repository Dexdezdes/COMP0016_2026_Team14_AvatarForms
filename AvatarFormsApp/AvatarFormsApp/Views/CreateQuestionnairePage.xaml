<Page
    x:Class="AvatarFormsApp.Views.CreateQuestionnairePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:AvatarFormsApp.Services"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="ContentArea" Padding="0">
        <!-- Hidden WebView2 used purely for network interception -->
        <WebView2 x:Name="HiddenWebView"
                  Width="1" Height="1"
                  Opacity="0"
                  IsHitTestVisible="False"
                  VerticalAlignment="Top"
                  HorizontalAlignment="Left" />

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="20" Margin="32,24,32,32">

                <StackPanel Spacing="6">
                    <TextBlock Text="Create Questionnaire"
                               Style="{StaticResource TitleTextBlockStyle}" />
                    <TextBlock Text="Import questions from a forms link or file, review the results, and create your questionnaire."
                               TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                        CornerRadius="12"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        Padding="20">
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Questionnaire Name" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBox PlaceholderText="Enter a name..."
                                     Text="{x:Bind ViewModel.QuestionnaireName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Description" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBox PlaceholderText="Enter a description of the questionnaire with proper context..."
                                     Text="{x:Bind ViewModel.QuestionnaireDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="96" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Questionnaire Forms Link" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBox x:Name="LinkTextBox"
                                     PlaceholderText="Paste your form link here..."
                                     Text="{x:Bind ViewModel.FormLink, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     TextChanged="LinkTextBox_TextChanged" />
                        </StackPanel>

                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <TextBlock Text="Or" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        </StackPanel>

                        <Grid ColumnSpacing="10" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Content="Browse file (.csv / .xlsx)" Click="BrowseButton_Click" />
                            <TextBlock Grid.Column="1"
                                       x:Name="PickedFileText"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                        CornerRadius="12"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        Padding="16"
                        Visibility="{x:Bind ViewModel.StatusMessage, Mode=OneWay,
                                     Converter={StaticResource StringToVisibilityConverter}}">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                                      Width="20" Height="20"
                                      VerticalAlignment="Top"
                                      Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay,
                                                   Converter={StaticResource BoolToVisibilityConverter}}" />

                        <TextBlock Grid.Column="1"
                                   Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                        CornerRadius="12"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        Padding="20"
                        Visibility="{x:Bind ViewModel.HasParsedQuestions, Mode=OneWay,
                                     Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Spacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Questions Preview"
                                       Style="{StaticResource SubtitleTextBlockStyle}" />
                            <TextBlock Text="Review each question before creating the questionnaire."
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>

                        <ItemsControl ItemsSource="{x:Bind ViewModel.ParsedQuestions, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:ParsedQuestion">
                                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                            CornerRadius="8"
                                            Padding="0"
                                            Margin="0,0,0,18">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="4" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <Rectangle Grid.Row="0"
                                                       Fill="{ThemeResource SystemFillColorNeutralBrush}"
                                                       RadiusX="8"
                                                       RadiusY="8" />

                                            <StackPanel Grid.Row="1" Padding="20,14,12,16" Spacing="10">
                                                <Grid ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}"
                                                               VerticalAlignment="Center">
                                                        <Run Text="Question " />
                                                        <Run Text="{x:Bind Index}" />
                                                    </TextBlock>

                                                    <!-- Question type badge -->
                                                    <Border Grid.Column="1"
                                                            CornerRadius="4"
                                                            Padding="8,3"
                                                            VerticalAlignment="Center"
                                                            Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}">
                                                        <TextBlock Text="{x:Bind TypeLabel}"
                                                                   FontSize="11"
                                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                    </Border>
                                                </Grid>

                                                <Grid ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBox Text="{x:Bind FullTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             FontSize="14"
                                                             FontWeight="SemiBold"
                                                             TextWrapping="Wrap"
                                                             Visibility="{x:Bind IsMatrix,
                                                                          Converter={StaticResource BoolToVisibilityConverter}}" />

                                                    <TextBox Text="{x:Bind Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             FontSize="14"
                                                             FontWeight="SemiBold"
                                                             TextWrapping="Wrap"
                                                             Visibility="{x:Bind IsMatrix,
                                                                          Converter={StaticResource BoolToVisibilityInverseConverter}}" />

                                                    <Button Grid.Column="1"
                                                            Content="&#xE74D;"
                                                            FontFamily="Segoe MDL2 Assets"
                                                            FontSize="14"
                                                            Padding="12,0"
                                                            BorderThickness="0"
                                                            VerticalAlignment="Stretch"
                                                            ToolTipService.ToolTip="Remove question"
                                                            Tag="{x:Bind}"
                                                            Click="RemoveQuestion_Click">
                                                        <Button.Resources>
                                                            <ResourceDictionary>
                                                                <SolidColorBrush x:Key="ButtonForeground"             Color="Red" />
                                                                <SolidColorBrush x:Key="ButtonForegroundPointerOver"  Color="Red" />
                                                                <SolidColorBrush x:Key="ButtonForegroundPressed"      Color="Red" />
                                                                <SolidColorBrush x:Key="ButtonBackground"             Color="Transparent" />
                                                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver"  Color="#15C42B1C" />
                                                                <SolidColorBrush x:Key="ButtonBackgroundPressed"      Color="#25C42B1C" />
                                                            </ResourceDictionary>
                                                        </Button.Resources>
                                                    </Button>
                                                </Grid>

                                                <!-- MCQ Options Preview -->
                                                <ItemsControl ItemsSource="{x:Bind Options}"
                                                              Visibility="{x:Bind HasOptions,
                                                                           Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="x:String">
                                                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,3,0,3">
                                                                <Ellipse Width="16" Height="16"
                                                                         Stroke="{ThemeResource TextFillColorSecondaryBrush}"
                                                                         StrokeThickness="1.5"
                                                                         VerticalAlignment="Center" />
                                                                <TextBlock Text="{x:Bind}"
                                                                           FontSize="13"
                                                                           VerticalAlignment="Center"
                                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                    <Button Content="Cancel" Click="Cancel_Click" />
                    <Button Content="Create Questionnaire"
                            Style="{StaticResource AccentButtonStyle}"
                            Click="Create_Click"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay,
                                        Converter={StaticResource BoolNegationConverter}}" />
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
