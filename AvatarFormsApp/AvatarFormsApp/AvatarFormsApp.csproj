<Project Sdk="Uno.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net10.0-maccatalyst</TargetFrameworks>
    <OutputType>Exe</OutputType>
    <UnoSingleProject>true</UnoSingleProject>

    <PublishTrimmed>true</PublishTrimmed>
    <MtouchLink>None</MtouchLink>
    
    <UnoDisableAutoMain>false</UnoDisableAutoMain>
    <UseInterpreter>true</UseInterpreter>
    <SupportedOSPlatformVersion>15.0</SupportedOSPlatformVersion>

    <UnoThemesVersion>5.2.13</UnoThemesVersion>
    <UnoToolkitVersion>5.2.14</UnoToolkitVersion>
    <UnoFeatures>Material;Toolkit;</UnoFeatures>

    <ApplicationId>com.companyname.avatarformsapp.v2</ApplicationId>
    <ApplicationDisplayVersion>1.0</ApplicationDisplayVersion>
    <ApplicationVersion>1</ApplicationVersion>
    <ApplicationTitle>AvatarFormsApp</ApplicationTitle>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Uno.Material.WinUI" />
    <PackageReference Include="Uno.Toolkit.WinUI" />
  </ItemGroup>

  <PropertyGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'maccatalyst'">
    <RuntimeIdentifier>maccatalyst-arm64</RuntimeIdentifier>
    <SuppressUserScriptSandboxing>true</SuppressUserScriptSandboxing>
    <EnableCodeSigning>false</EnableCodeSigning>
    <CodesignKey>-</CodesignKey>
    <CodesignEntitlements>Platforms/maccatalyst/Entitlements.plist</CodesignEntitlements>
    <UseHardenedRuntime>false</UseHardenedRuntime>
    <CreatePackage>false</CreatePackage>
</PropertyGroup>
</Project>