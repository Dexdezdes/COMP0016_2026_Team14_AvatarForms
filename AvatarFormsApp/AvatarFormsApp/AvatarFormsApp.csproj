<Project Sdk="Uno.Sdk">
    <PropertyGroup>
        <TargetFrameworks Condition="$([MSBuild]::IsOSPlatform('windows'))">net10.0-windows10.0.19041.0</TargetFrameworks>
        <TargetFrameworks Condition="!$([MSBuild]::IsOSPlatform('windows'))">net10.0-maccatalyst</TargetFrameworks>
        <OutputType>Exe</OutputType>
        <UnoSingleProject>true</UnoSingleProject>

        <PublishTrimmed Condition="!$([MSBuild]::IsOSPlatform('windows'))">true</PublishTrimmed>
        <PublishTrimmed Condition="$([MSBuild]::IsOSPlatform('windows'))">false</PublishTrimmed>
        <MtouchLink>None</MtouchLink>

        <UnoDisableAutoMain>false</UnoDisableAutoMain>
        <UseInterpreter>true</UseInterpreter>
        <SupportedOSPlatformVersion Condition="!$([MSBuild]::IsOSPlatform('windows'))">15.0</SupportedOSPlatformVersion>

        <UnoFeatures>Material;Toolkit;</UnoFeatures>
        <UnoPackageId>AvatarFormsApp</UnoPackageId>
        
        <ApplicationId>AvatarFormsApp</ApplicationId>
        <PackageId>AvatarFormsApp</PackageId>
        <AssemblyName>AvatarFormsApp</AssemblyName>
        <ApplicationDisplayVersion>1.0</ApplicationDisplayVersion>
        <ApplicationVersion>1</ApplicationVersion>
        <ApplicationTitle>AvatarFormsApp</ApplicationTitle>
   </PropertyGroup>

    <PropertyGroup Condition="!$([MSBuild]::IsOSPlatform('windows'))">
        <DefineConstants>$(DefineConstants);DEV_PYTHON_ENV='$(MSBuildProjectDirectory)/../env/bin/python3'</DefineConstants>
    </PropertyGroup>

    <PropertyGroup Condition="$([MSBuild]::IsOSPlatform('windows'))">
        <DefineConstants>$(DefineConstants);DEV_PYTHON_ENV='$(MSBuildProjectDirectory)/../env/Scripts/python.exe'</DefineConstants>
    </PropertyGroup>
    
    <PropertyGroup Condition="$([MSBuild]::IsOSPlatform('windows'))">
        <ApplicationIdGuid>71833983-4903-4B82-95E0-0761E094209C</ApplicationIdGuid>
        <AppxPackageGuid>71833983-4903-4B82-95E0-0761E094209C</AppxPackageGuid>
        <PublisherName>Group14</PublisherName>
        <AppxPackagePublisherName>CN=Group14</AppxPackagePublisherName>
        <WebView2EnableMsixTooling>true</WebView2EnableMsixTooling>
        <ErrorOnDuplicatePublishOutputFiles>false</ErrorOnDuplicatePublishOutputFiles>
    </PropertyGroup>
    
    <ItemGroup Condition="!$([MSBuild]::IsOSPlatform('windows'))">
        <PackageReference Include="Uno.Material.WinUI" />
        <PackageReference Include="Uno.Toolkit.WinUI" />
        <PackageReference Include="Uno.Microsoft.Xaml.Behaviors.WinUI.Managed" />
    </ItemGroup>

    <PropertyGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'maccatalyst'">
        <RuntimeIdentifier>maccatalyst-arm64</RuntimeIdentifier>
        <SuppressUserScriptSandboxing>true</SuppressUserScriptSandboxing>
        <EnableCodeSigning>false</EnableCodeSigning>
        <CodesignKey>-</CodesignKey>
        <CodesignEntitlements>Platforms/maccatalyst/Entitlements.plist</CodesignEntitlements>
        <UseHardenedRuntime>false</UseHardenedRuntime>
        <CreatePackage>false</CreatePackage>
    </PropertyGroup>

    <ItemGroup>
        <Content Include="../../Backend/**/*">
            <Link>Backend/%(RecursiveDir)%(FileName)%(Extension)</Link>
            <LogicalName>Backend/%(RecursiveDir)%(FileName)%(Extension)</LogicalName>
            <CopyToOutputDirectory>Always</CopyToOutputDirectory>
        </Content>
        <Content Include="../../HeadTTS/**/*">
            <Link>HeadTTS/%(RecursiveDir)%(FileName)%(Extension)</Link>
            <LogicalName>HeadTTS/%(RecursiveDir)%(FileName)%(Extension)</LogicalName>
            <CopyToOutputDirectory>Always</CopyToOutputDirectory>
        </Content>
    </ItemGroup>
    <ItemGroup>
        <PackageReference Include="CommunityToolkit.Mvvm" />
        <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" />
        <PackageReference Include="Microsoft.EntityFrameworkCore.Tools">
          <PrivateAssets>all</PrivateAssets>
          <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
        </PackageReference>
        <PackageReference Include="Microsoft.Playwright" />
        <PackageReference Include="SQLitePCLRaw.bundle_e_sqlite3" />
        <PackageReference Include="Microsoft.Extensions.Hosting" />
        <PackageReference Include="Microsoft.Web.WebView2" />
        <PackageReference Include="Newtonsoft.Json" />
    </ItemGroup>

    <ItemGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'windows'">
        <PackageReference Include="WinUIEx" />
        <PackageReference Include="Microsoft.Xaml.Behaviors.WinUI.Managed" />
    </ItemGroup>

    <ItemGroup>
        <Content Include="Assets\**\*" Exclude="bin\**;obj\**">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </Content>
    </ItemGroup>

    <ItemGroup>
      <Content Remove="..\..\Backend\google_gemma-3-4b-it-Q6_K.llamafile" />
      <Content Remove="..\..\Backend\requirements.txt" />
    </ItemGroup>

    </Project>
